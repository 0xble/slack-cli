#!/usr/bin/env bash
set -euo pipefail

BIN_PATH="${SLACK_CLI_INSTALL_PATH:-$HOME/.local/bin/slack-cli}"
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
EXPECTED_VERSION="$("$REPO_ROOT/bin/version")"

if [[ ! -x "$BIN_PATH" ]]; then
  echo "missing installed binary: $BIN_PATH" >&2
  exit 1
fi

VERSION_OUTPUT="$("$BIN_PATH" version 2>&1)"
echo "$VERSION_OUTPUT"

if ! printf '%s\n' "$VERSION_OUTPUT" | grep -Fq -- "$EXPECTED_VERSION"; then
  echo "installed binary version mismatch: expected $EXPECTED_VERSION" >&2
  exit 1
fi

"$BIN_PATH" --help >/dev/null
echo "smoke ok: slack-cli"
